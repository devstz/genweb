# URL бэкенда для проксирования API (только на сервере, не попадает в браузер)
# Локально: API бэкенд на localhost:8000
# Прод: URL вашего бэкенда (внутренний или публичный)
API_URL=http://bot_api:8000

# Токен Telegram-бота: только сервер (getMe → username, кеш на процесс). Не использовать NEXT_PUBLIC_.
# Локально обычно в .env.local
TELEGRAM_BOT_TOKEN=
